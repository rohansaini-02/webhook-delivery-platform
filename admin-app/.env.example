# Google OAuth Client IDs
EXPO_PUBLIC_WEB_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"
EXPO_PUBLIC_EXPO_CLIENT_ID="your-expo-client-id.apps.googleusercontent.com"

# Backend API URL
# For local development: comment this out — Expo auto-detects the IP
# For production APK build: set this to your deployed backend URL
# EXPO_PUBLIC_API_URL="https://your-backend.onrender.com/api/v1"
